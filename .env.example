# Client-side fallback API key.
# Used only when the local proxy does not have COHERE_API_KEY set server-side.
VITE_COHERE_API_KEY=gXEFm1bhXanKDoDL0gIdchnIbw0A7Jwzgpn59KYO

# Leave empty in Vite dev mode so relative /api is proxied by Vite.
# Set this when serving the app from Laragon, e.g. http://localhost:3001
VITE_API_BASE_URL=

# Preferred server-side key for the Express proxy.
COHERE_API_KEY=

# Dev write-back / proxy server port (Express, dev only)
DEV_SERVER_PORT=3001
